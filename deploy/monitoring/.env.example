# Скопировать в /opt/panzers-monitoring/.env и заполнить. НЕ коммитить реальный .env.
# Сильный пароль: openssl rand -hex 16

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-strong-password
# Публичный URL Grafana (через app-Caddy). На проде — grafana.panzers.tg.
GRAFANA_ROOT_URL=https://grafana.panzers.tg
