{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["panzers", "load"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Panzers — Нагрузка",
  "uid": "panzers-load",
  "version": 1,
  "panels": [
    {
      "type": "row",
      "title": "Контейнеры (по поду)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU по контейнеру (%)",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 2,
      "fieldConfig": {
        "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_cpu_usage_seconds_total{name=~\".+\"}[$__rate_interval])) * 100", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Память по контейнеру (working set)",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 3,
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (container_memory_working_set_bytes{name=~\".+\"})", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Сеть RX по контейнеру",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 4,
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_network_receive_bytes_total{name=~\".+\"}[$__rate_interval]))", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Сеть TX по контейнеру",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 5,
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        { "refId": "A", "expr": "sum by (name) (rate(container_network_transmit_bytes_total{name=~\".+\"}[$__rate_interval]))", "legendFormat": "{{name}}" }
      ]
    },
    {
      "type": "row",
      "title": "Хост",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 6,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU хоста (%)",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 18 },
      "id": 7,
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[$__rate_interval])) * 100)", "legendFormat": "CPU used %" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Память хоста (% занято)",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 18 },
      "id": 8,
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100", "legendFormat": "RAM used %" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Load average",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 18 },
      "id": 9,
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "fillOpacity": 0, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "node_load1", "legendFormat": "1m" },
        { "refId": "B", "expr": "node_load5", "legendFormat": "5m" },
        { "refId": "C", "expr": "node_load15", "legendFormat": "15m" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Диск / (% занято)",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "id": 10,
      "fieldConfig": {
        "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 20, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} / node_filesystem_size_bytes{mountpoint=\"/\",fstype!~\"tmpfs|overlay|squashfs\"} * 100)", "legendFormat": "disk used %" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Сеть хоста",
      "datasource": { "type": "prometheus", "uid": "panzers-vm" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "id": 11,
      "fieldConfig": {
        "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10, "showPoints": "never" } },
        "overrides": []
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(node_network_receive_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval]))", "legendFormat": "RX" },
        { "refId": "B", "expr": "sum(rate(node_network_transmit_bytes_total{device!~\"lo|veth.*|docker.*|br-.*\"}[$__rate_interval]))", "legendFormat": "TX" }
      ]
    }
  ]
}
